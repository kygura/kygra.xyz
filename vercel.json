{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/notion.js": { "runtime": "nodejs@20.x" },
    "api/posts.js": { "runtime": "nodejs@20.x" },
    "api/post/[slug].js": { "runtime": "nodejs@20.x" }
  }
}
